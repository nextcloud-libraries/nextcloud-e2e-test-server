{
	"include": ["./lib"],
	"exclude": ["./cypress"],
	"compilerOptions": {
		"lib": [
			"ES2024",
			"DOM"
		],
		"types": [
			"cypress",
			"node"
		],
		"rootDir": "lib",
		"outDir": "./dist",
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"erasableSyntaxOnly": true,
		"esModuleInterop": true
	}
}